# Add Go binaries to PATH
export PATH=$PATH:$HOME/go/bin
# Add to ~/.bashrc
Android() {
    # We use sudo to become root, which Android allows to talk to 'am'
    sudo ANDROID_DATA=/data \
         ANDROID_ROOT=/system \
         PATH=/system/bin:/system/xbin:$PATH \
         LD_LIBRARY_PATH=/system/lib64:/system/lib \
         /system/bin/sh -c "$*"
}

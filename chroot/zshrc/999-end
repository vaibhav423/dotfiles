# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Ensure common npm global bin locations are on PATH so globally installed
# packages remain runnable even when nvm is lazy-loaded.
if [ -d "$HOME/.npm-global/bin" ]; then
    export PATH="$HOME/.npm-global/bin:$PATH"
fi
if [ -d "$HOME/.npm-packages/bin" ]; then
    export PATH="$HOME/.npm-packages/bin:$PATH"
fi
if [ -d "$HOME/.npm/bin" ]; then
    export PATH="$HOME/.npm/bin:$PATH"
fi
if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi
# If nvm has installed node versions, add their bin dirs so global npm
# executables are available before nvm is sourced by the lazy loader.
if [ -d "$NVM_DIR/versions/node" ]; then
    for v in "$NVM_DIR/versions/node"/*; do
        [ -d "$v/bin" ] && export PATH="$v/bin:$PATH"
    done
fi
export GEMINI_API_KEY=$(cat ~/gemini)


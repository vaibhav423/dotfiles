usage_copilot() {
    local token
    token=$(jq -r '.[].oauth_token' ~/.config/github-copilot/apps.json 2>/dev/null)
    
    if [ -z "$token" ]; then
        echo "Error: Copilot token not found."
        return 1
    fi


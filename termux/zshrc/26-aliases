#==============================================================================
# DNS/NETWORK MANAGEMENT
#==============================================================================

# Clear DNS redirections
cldns() {
    su -c "iptables -t nat -D PREROUTING -i ap0 -p tcp --dport 53 -j REDIRECT --to-port 1053"
    su -c "iptables -t nat -D PREROUTING -i ap0 -p udp --dport 53 -j REDIRECT --to-port 1053"
    sudo iptables -t nat -D PREROUTING -i ap0 -p tcp --dport 80 -j REDIRECT --to-port 8080
    sudo kill "$(cat /sdcard/dnsmasq-ap0.pid)"
}

# Setup DNS redirections
stdns() {
    sudo pkill -u dns_tether dnsmasq
    su -c "iptables -t nat -I PREROUTING -i ap0 -p tcp --dport 53 -j REDIRECT --to-port 1053"
    su -c "iptables -t nat -I PREROUTING -i ap0 -p udp --dport 53 -j REDIRECT --to-port 1053"
    sudo iptables -t nat -I PREROUTING -i ap0 -p tcp --dport 80 -j REDIRECT --to-port 8080
    sudo dnsmasq --no-resolv --port=1053 --interface=ap0 \
        --address=/#/$(sudo ip -4 -o addr show dev ap0 | awk '{print $4}' | cut -d/ -f1) \
        --pid-file=/sdcard/dnsmasq-ap0.pid
}


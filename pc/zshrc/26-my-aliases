bafind() {
    # Step 1: User selects a category
    local category=$(pacman -Sg | grep blackarch | fzf --prompt="Select a BlackArch Category > " --layout=reverse)

    # Exit if no category was selected (e.g., user pressed Esc)
    [ -z "$category" ] && return

    # Step 2: User selects a tool from within the chosen category, with a live preview
    # The awk command standardizes the output for consistent parsing
    pacman -Sg "${category%% *}" | awk '{print $2}' | \
    fzf --prompt="Select a Tool > " --layout=reverse \
        --preview 'pacman -Si {1}' \
        --preview-window 'right,60%,border-left'
}

alias bk='sudo pacman -S $(bafind)'
_fzf_fill_cli() {
  # 1. Get the list of items (customize 'my-list-command' to your needs)
  # Example: Find all markdown files and pipe them to fzf
  local selected_item
  selected_item=$(find . -maxdepth 2 -type f -name "*.md" | fzf --reverse --print-query)

  # Check if fzf was cancelled or returned an empty line
  if [[ -z "$selected_item" ]]; then
    return 0
  fi

  # 2. Extract the actual selection (fzf returns the query on the first line if --print-query is used)
  # For simplicity, we assume the selection is what we need.

  # 3. Insert the selection into the current command line buffer
  # If the selected item is multiline, use only the first line.
  local item_to_insert
  item_to_insert=$(echo "$selected_item" | head -n 1)

  # This is the magic part: it sets the Readline variables
  READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT}${item_to_insert}${READLINE_LINE:$READLINE_POINT}"
  READLINE_POINT=$((READLINE_POINT + ${#item_to_insert}))
}

# create python virtualenv and activate with given name 
# do not create if already exists
pveng(){
    source ~/Water/crap/python/bin/activate
}
pven() {
    if [ -z "$1" ]; then
        echo "Usage: mkvenv <env-name>"
        return 1
    fi
    if [ ! -d "$1" ]; then
        python -m venv "$1"
        echo "Virtual environment '$1' created."
    else
        echo "Virtual environment '$1' already exists."
    fi
    source "$1/bin/activate"
}

bainstalled() {
    # Create a searchable list of "package: description" for locally installed packages
    # and filter it to show only those belonging to the BlackArch repository.
    pacman -Qs . | paste - - | sed -e 's|^local/||' -e 's/ [0-9].*?\t/: /' | \
    grep -Fwf <(comm -12 <(pacman -Q | cut -d' ' -f1 | sort) <(pacman -Sl blackarch | cut -d' ' -f2 | sort)) | \
    fzf --prompt="Search Installed BlackArch Tools > " --layout=reverse \
        --with-nth=.. --delimiter=':' \
        --preview 'echo {} | cut -d: -f1 | xargs pacman -Qi' \
        --preview-window 'right,60%,border-left' | \
    cut -d: -f1 | xargs
}


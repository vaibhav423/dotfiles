#!/usr/bin/env bash
set -euo pipefail
if [ "$EUID" -ne 0 ]; then
    notify-send err
fi
if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <vm_name>"
    exit 1
fi

vm_name="$1"
file_path="/home/ixdire/foo.txt"
holdtime=100
pause_time_ms=10

if [ ! -f "$file_path" ]; then
    echo "File not found: $file_path"
    exit 1
fi


declare -A key_map=(
    ['a']=0x04    ['b']=0x05    ['c']=0x06    ['d']=0x07    ['e']=0x08    ['f']=0x09
    ['g']=0x0A    ['h']=0x0B    ['i']=0x0C    ['j']=0x0D    ['k']=0x0E    ['l']=0x0F
    ['m']=0x10    ['n']=0x11    ['o']=0x12    ['p']=0x13    ['q']=0x14    ['r']=0x15
    ['s']=0x16    ['t']=0x17    ['u']=0x18    ['v']=0x19    ['w']=0x1A    ['x']=0x1B
    ['y']=0x1C    ['z']=0x1D
    ['A']="0xe1 0x04"   ['B']="0xe1 0x05"   ['C']="0xe1 0x06"   ['D']="0xe1 0x07"
    ['E']="0xe1 0x08"   ['F']="0xe1 0x09"   ['G']="0xe1 0x0A"   ['H']="0xe1 0x0B"
    ['I']="0xe1 0x0C"   ['J']="0xe1 0x0D"   ['K']="0xe1 0x0E"   ['L']="0xe1 0x0F"
    ['M']="0xe1 0x10"   ['N']="0xe1 0x11"   ['O']="0xe1 0x12"   ['P']="0xe1 0x13"
    ['Q']="0xe1 0x14"   ['R']="0xe1 0x15"   ['S']="0xe1 0x16"   ['T']="0xe1 0x17"
    ['U']="0xe1 0x18"   ['V']="0xe1 0x19"   ['W']="0xe1 0x1A"   ['X']="0xe1 0x1B"
    ['Y']="0xe1 0x1C"   ['Z']="0xe1 0x1D"
    ['1']=0x1E    ['2']=0x1F    ['3']=0x20    ['4']=0x21    ['5']=0x22
    ['6']=0x23    ['7']=0x24    ['8']=0x25    ['9']=0x26    ['0']=0x27
    ['!']="0xe1 0x1e"   ['@']="0xe1 0x1f"   ['#']="0xe1 0x20"   ['$']="0xe1 0x21"
    ['%']="0xe1 0x22"   ['^']="0xe1 0x23"   ['&']="0xe1 0x24"   ['*']="0xe1 0x25"
    ['(']="0xe1 0x26"   [')']="0xe1 0x27"
    ['-']=0x2D    ['=']=0x2E    ['[']=0x2F    [']']=0x30    ['\']=0x64
    [';']=0x33    ["'"]=0x34    [',']=0x36    ['.']=0x37    ['/']=0x38
    ['`']=0x35
    ['_']="0xe1 0x2D"   ['+']="0xe1 0x2E"   ['{']="0xe1 0x2F"   ['}']="0xe1 0x30"
    ['|']="0xe1 0x64"   [':']="0xe1 0x33"   ['"']="0xe1 0x34"   ['<']="0xe1 0x36"
    ['>']="0xe1 0x37"   ['?']="0xe1 0x38"   ['~']="0xe1 0x35"
    [' ']=0x2C
)

# Read file ensuring trailing newlines are preserved
content=$(cat "$file_path"; echo -n 'x')
content="${content%x}"

for (( i=0; i<${#content}; i++ )); do
    char="${content:$i:1}"
    
    if [[ "$char" == $'\n' ]]; then
        codes="0x28" # Enter key
    elif [[ "$char" == $'\t' ]]; then
        codes="0x2B" # Tab key
    elif [[ -n "${key_map[$char]+_}" ]]; then
        codes="${key_map[$char]}"
    else
        continue
    fi

    read -ra key_array <<< "$codes"
    virsh send-key "$vm_name" --codeset usb "${key_array[@]}" --holdtime "$holdtime" > /dev/null 2>&1

    if [[ "$char" == " " ]]; then
        sleep "$(awk "BEGIN {print $pause_time_ms/1000}")"
    fi
done
